{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "esModuleInterop": true,
        "strict": true,
        "outDir": "dist",
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "hardhat.config.ts",
        "scripts/**/*.ts",
        "test/**/*.ts",
        "typechain-types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "frontend",
        "api"
    ]
}